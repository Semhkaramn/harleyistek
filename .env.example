# ═══════════════════════════════════════════════════════════════
# TELEGRAM API BİLGİLERİ
# https://my.telegram.org adresinden alın
# ═══════════════════════════════════════════════════════════════
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ═══════════════════════════════════════════════════════════════
# SESSION STRING
# generate_session.py ile oluşturun
# ═══════════════════════════════════════════════════════════════
SESSION_STRING=

# ═══════════════════════════════════════════════════════════════
# KORUNAN GRUPLAR
# Virgülle ayırarak birden fazla grup ID'si ekleyebilirsiniz
# Grup ID'sini öğrenmek için @userinfobot kullanabilirsiniz
# ═══════════════════════════════════════════════════════════════
PROTECTED_GROUPS=-1001234567890

# ═══════════════════════════════════════════════════════════════
# LOG GRUBU
# Komutların alınacağı ve logların gönderileceği grup ID'si
# Bot bu grupta mesaj atabilmeli!
# Komutlar: /ac /kapat /temizle
# ═══════════════════════════════════════════════════════════════
LOG_CHANNEL_ID=-1001122334455

# ═══════════════════════════════════════════════════════════════
# GRUP SETLERİ (Çoklu Grup Desteği)
# Her set için ayrı log kanalı tanımlayabilirsiniz
# ═══════════════════════════════════════════════════════════════
PROTECTED_GROUPS_1=-1001234567890,-1001234567891
LOG_CHANNEL_ID_1=-1001122334455

PROTECTED_GROUPS_2=-1001234567892,-1001234567893
LOG_CHANNEL_ID_2=-1001122334456

