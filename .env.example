# ═══════════════════════════════════════════════════════════════
# TELEGRAM API BİLGİLERİ
# https://my.telegram.org adresinden alın
# ═══════════════════════════════════════════════════════════════
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ═══════════════════════════════════════════════════════════════
# SESSION STRING (Opsiyonel)
# Telethon session string - ilk çalıştırmada otomatik oluşturulur
# VPS'de kullanmak için generate_session.py ile oluşturun
# ═══════════════════════════════════════════════════════════════
SESSION_STRING=

# ═══════════════════════════════════════════════════════════════
# KORUNAN GRUPLAR
# Virgülle ayırarak birden fazla grup ID'si ekleyebilirsiniz
# Boş bırakırsanız tüm gruplar korunur
# Grup ID'sini öğrenmek için @userinfobot kullanabilirsiniz
# ═══════════════════════════════════════════════════════════════
PROTECTED_GROUPS=-1001234567890,-1009876543210

# ═══════════════════════════════════════════════════════════════
# LOG KANALI
# İstatistiklerin gönderileceği kanal ID'si
# Botun bu kanalda admin olması gerekir!
# ═══════════════════════════════════════════════════════════════
LOG_CHANNEL_ID=-1001122334455

# ═══════════════════════════════════════════════════════════════
# ADMIN KULLANICILAR
# Komut verebilecek kullanıcı ID'leri (virgülle ayırın)
# Boş bırakırsanız sadece hesap sahibi komut verebilir
# ID öğrenmek için: @userinfobot
# ═══════════════════════════════════════════════════════════════
ADMIN_IDS=123456789,987654321

# ═══════════════════════════════════════════════════════════════
# FLOOD AYARLARI
# ═══════════════════════════════════════════════════════════════
# Kaç saniye içinde kontrol edilecek (varsayılan: 3)
FLOOD_WINDOW_SECONDS=3

# Kaç istek flood sayılacak (varsayılan: 10)
FLOOD_THRESHOLD=10

# ═══════════════════════════════════════════════════════════════
# İSTATİSTİK AYARLARI
# ═══════════════════════════════════════════════════════════════
# Kaç saniyede bir istatistik özeti gönderilecek (varsayılan: 3600 = 1 saat)
STATS_INTERVAL=3600
